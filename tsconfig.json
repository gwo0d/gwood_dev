{
	"compilerOptions": {
		"strict": true,
		"target": "ESNext",
		"module": "ESNext",
		"moduleResolution": "Bundler",
		"allowSyntheticDefaultImports": true,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"noEmit": true,
		"isolatedModules": true,
		"types": ["node"],
		"baseUrl": "./"
	},
	"include": [
		"src/**/*.ts",
		"src/**/*.d.ts",
		"scripts/**/*.ts",
		"vite.config.ts"
	]
}
